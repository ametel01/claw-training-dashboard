{
  "name": "claw-training-dashboard",
  "private": true,
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "concurrently -k -n server,client -c cyan,yellow \"bun run dev:server\" \"bun run dev:client\"",
    "dev:client": "vite",
    "dev:server": "PORT=8080 tsx watch server/src/index.ts",
    "build": "vite build && bun run build:dashboard && bun run build:server",
    "preview": "vite preview",
    "build:dashboard": "bun build ./dashboard/src/main.ts --outfile ./dashboard/app.js --target browser --format iife --minify",
    "build:server": "bun build ./server/src/index.ts ./server/src/cli/gym531.ts ./server/src/cli/health-pipeline.ts ./dashboard/src/export-data.ts --outdir ./server/dist --target node --format esm",
    "export:data": "if [ ! -f ./server/dist/dashboard/src/export-data.js ]; then bun run build:server >/dev/null; fi; NODE_NO_WARNINGS=1 node ./server/dist/dashboard/src/export-data.js",
    "start": "NODE_NO_WARNINGS=1 node ./server/dist/server/src/index.js",
    "gym531": "NODE_NO_WARNINGS=1 node ./server/dist/server/src/cli/gym531.js",
    "health:pipeline": "NODE_NO_WARNINGS=1 node ./server/dist/server/src/cli/health-pipeline.js",
    "lint": "biome lint ./src ./test ./vite.config.ts ./vitest.config.ts ./playwright.config.ts",
    "format": "biome format --write ./src",
    "typecheck": "tsc --noEmit",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "NODE_NO_WARNINGS=1 vitest run test/unit",
    "test:integration": "NODE_NO_WARNINGS=1 bun run build:server && NODE_NO_WARNINGS=1 vitest run test/server test/cli",
    "test:e2e": "NODE_NO_WARNINGS=1 bun run build && NODE_NO_WARNINGS=1 playwright test",
    "test:watch": "NODE_NO_WARNINGS=1 vitest",
    "test:ci": "bun run verify && bun run test:e2e",
    "verify": "bun run format && bun run typecheck && bun run lint && bun run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "concurrently": "^9.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.3.0",
    "lucide-react": "^0.577.0",
    "multer": "^2.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  }
}
