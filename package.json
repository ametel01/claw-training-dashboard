{
  "name": "claw-training-dashboard",
  "private": true,
  "packageManager": "bun@1.3.9",
  "scripts": {
    "build": "bun build ./dashboard/src/main.ts --outfile ./dashboard/app.js --target browser --format iife --minify",
    "export:data": "bun run --bun ./dashboard/src/export-data.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "verify": "bun run typecheck && bun run lint && bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.6.1",
    "typescript": "^5.9.3"
  }
}
