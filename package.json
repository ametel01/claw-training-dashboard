{
  "name": "claw-training-dashboard",
  "private": true,
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "vite",
    "build": "vite build && bun run build:dashboard && bun run build:server",
    "preview": "vite preview",
    "build:dashboard": "bun build ./dashboard/src/main.ts --outfile ./dashboard/app.js --target browser --format iife --minify",
    "build:server": "bun build ./server/src/index.ts ./server/src/cli/gym531.ts ./server/src/cli/health-pipeline.ts ./dashboard/src/export-data.ts --outdir ./server/dist --target node --format esm",
    "export:data": "if [ ! -f ./server/dist/dashboard/src/export-data.js ]; then bun run build:server >/dev/null; fi; NODE_NO_WARNINGS=1 node ./server/dist/dashboard/src/export-data.js",
    "start": "NODE_NO_WARNINGS=1 node ./server/dist/server/src/index.js",
    "gym531": "NODE_NO_WARNINGS=1 node ./server/dist/server/src/cli/gym531.js",
    "health:pipeline": "NODE_NO_WARNINGS=1 node ./server/dist/server/src/cli/health-pipeline.js",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "typecheck": "tsc --noEmit",
    "verify": "bun run typecheck && bun run lint"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.3.0",
    "lucide-react": "^0.577.0",
    "multer": "^2.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  }
}
